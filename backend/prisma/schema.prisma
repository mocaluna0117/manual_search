generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
  runtime = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model ManualCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  manuals   Manual[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Manual {
  id            String            @id @default(uuid())
  title         String
  description   String?
  fileKey       String            @map("file_key") // S3上のファイルの場所(キー)
  fileName      String            @map("file_name") // 元のPDFファイル名
  mimeType      String            @map("mime_type") @default("application/pdf")
  size          Int               // ファイルサイズ（バイト）
  categoryId    String?
  category      ManualCategory?   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  chunks        ManualChunk[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// RAG用: マニュアルを検索しやすい断片に分割したもの。
// embeddingはPrisma未対応のpgvector型なのでUnsupportedで宣言し、SQLで直接扱う
model ManualChunk {
  id         String                       @id @default(uuid())
  manualId   String                       @map("manual_id")
  manual     Manual                       @relation(fields: [manualId], references: [id], onDelete: Cascade)
  chunkIndex Int                          @map("chunk_index")
  content    String
  embedding  Unsupported("vector(1024)")? // Titan Embeddings V2 = 1024次元
  createdAt  DateTime                     @default(now()) @map("created_at")

  @@unique([manualId, chunkIndex])
}